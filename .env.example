# =============================================
# mcp-gateway Environment Configuration
# =============================================
# Copy this file to .env and fill in the values.
# Never commit .env files to version control.
# =============================================

# =============================================
# Server Configuration
# =============================================
PORT=8080
NODE_ENV=development

# =============================================
# Redis Configuration
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================
# TLS Configuration
# =============================================
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# =============================================
# Observability
# =============================================
# OpenTelemetry Collector Endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# Service name for tracing
OTEL_SERVICE_NAME=mcp-gateway

# =============================================
# Rate Limiting
# =============================================
RATE_LIMIT_STORE=redis
RATE_LIMIT_DEFAULT_RPM=100
RATE_LIMIT_DEFAULT_RPD=10000

# =============================================
# Cache Configuration
# =============================================
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_DEFAULT_TTL=300

# =============================================
# Audit Configuration
# =============================================
AUDIT_ENABLED=true
AUDIT_STORAGE=file
AUDIT_FILE_PATH=./logs/audit.json
AUDIT_RETENTION_DAYS=90

# =============================================
# Configuration Paths
# =============================================
TENANT_CONFIG_DIR=./tenants
GATEWAY_CONFIG_PATH=./gateway.yaml

# =============================================
# API Keys (for testing only, use secrets in prod)
# =============================================
API_KEY=

# =============================================
# JWT/OIDC Configuration
# =============================================
JWT_ISSUER=
JWT_AUDIENCE=mcp-gateway
JWT_JWKS_URI=
