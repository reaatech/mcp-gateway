{
  "name": "@reaatech/mcp-gateway-gateway",
  "version": "1.0.0",
  "description": "MCP Gateway server — Express-based gateway with authentication, rate limiting, caching, and fan-out",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/mcp-gateway.git",
    "directory": "packages/gateway"
  },
  "homepage": "https://github.com/reaatech/mcp-gateway/tree/main/packages/gateway#readme",
  "bugs": {
    "url": "https://github.com/reaatech/mcp-gateway/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "bin": {
    "mcp-gateway": "./dist/cli.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/mcp-gateway-core": "workspace:*",
    "@reaatech/mcp-gateway-auth": "workspace:*",
    "@reaatech/mcp-gateway-rate-limit": "workspace:*",
    "@reaatech/mcp-gateway-cache": "workspace:*",
    "@reaatech/mcp-gateway-allowlist": "workspace:*",
    "@reaatech/mcp-gateway-validation": "workspace:*",
    "@reaatech/mcp-gateway-fanout": "workspace:*",
    "@reaatech/mcp-gateway-audit": "workspace:*",
    "@reaatech/mcp-gateway-observability": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/express-serve-static-core": "^5.0.0"
  }
}
