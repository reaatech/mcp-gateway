{
  "name": "@reaatech/mcp-gateway-rate-limit",
  "version": "1.1.2",
  "description": "Per-tenant rate limiting with token bucket algorithm",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/mcp-gateway.git",
    "directory": "packages/rate-limit"
  },
  "homepage": "https://github.com/reaatech/mcp-gateway/tree/main/packages/rate-limit#readme",
  "bugs": {
    "url": "https://github.com/reaatech/mcp-gateway/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js",
      "require": "./dist/fastify.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/mcp-gateway-core": "workspace:*",
    "redis": "^6.0.1"
  },
  "peerDependencies": {
    "fastify": "^5"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^6.0.0"
  }
}
