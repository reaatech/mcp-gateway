{
  "name": "@reaatech/mcp-gateway-audit",
  "version": "1.0.0",
  "description": "Compliance audit trail logging for mcp-gateway",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/mcp-gateway.git",
    "directory": "packages/audit"
  },
  "homepage": "https://github.com/reaatech/mcp-gateway/tree/main/packages/audit#readme",
  "bugs": {
    "url": "https://github.com/reaatech/mcp-gateway/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/mcp-gateway-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
