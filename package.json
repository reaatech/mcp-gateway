{
  "name": "mcp-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Production MCP gateway with authentication, rate limiting, schema enforcement, tool allowlists, audit trail, fan-out routing, and response caching",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "type": "module",
  "keywords": [
    "mcp",
    "gateway",
    "api-gateway",
    "auth",
    "rate-limiting",
    "caching",
    "model-context-protocol",
    "oauth",
    "oidc",
    "redis",
    "observability"
  ],
  "scripts": {
    "build": "pnpm install && turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/mcp-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/mcp-gateway/issues"
  },
  "homepage": "https://github.com/reaatech/mcp-gateway#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@vitest/coverage-v8": "3.2.4",
    "turbo": "^2.9.14",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"],
    "overrides": {
      "fast-uri": "3.1.2",
      "hono": "4.12.19",
      "ip-address": "10.1.1",
      "protobufjs": "8.0.3"
    }
  }
}
